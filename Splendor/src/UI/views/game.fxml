<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.HBox?>

<AnchorPane fx:id="root"
            prefHeight="900.0" prefWidth="1400.0"
            minHeight="900.0" minWidth="1400.0"
            maxHeight="900.0" maxWidth="1400.0"
            xmlns="http://javafx.com/javafx/8"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="UI.controllers.Controller">

    <children>
        <!-- Sky -->
        <ImageView fx:id="gameSky"
                   fitWidth="1400.0"
                   fitHeight="900.0"
                   preserveRatio="false" />

        <!-- Cloud layer 1 -->
        <ImageView fx:id="gameCloud1A" fitWidth="1400.0" fitHeight="900.0" preserveRatio="false" />
        <ImageView fx:id="gameCloud1B" fitWidth="1400.0" fitHeight="900.0" preserveRatio="false" />

        <!-- Cloud layer 2 -->
        <ImageView fx:id="gameCloud2A" fitWidth="1400.0" fitHeight="900.0" preserveRatio="false" />
        <ImageView fx:id="gameCloud2B" fitWidth="1400.0" fitHeight="900.0" preserveRatio="false" />

        <!-- Cloud layer 3 -->
        <ImageView fx:id="gameCloud3A" fitWidth="1400.0" fitHeight="900.0" preserveRatio="false" />
        <ImageView fx:id="gameCloud3B" fitWidth="1400.0" fitHeight="900.0" preserveRatio="false" />

        <!-- Cloud layer 4 -->
        <ImageView fx:id="gameCloud4A" fitWidth="1400.0" fitHeight="900.0" preserveRatio="false" />
        <ImageView fx:id="gameCloud4B" fitWidth="1400.0" fitHeight="900.0" preserveRatio="false" />

        <!-- Cloud layer 5 -->
        <ImageView fx:id="gameCloud5A" fitWidth="1400.0" fitHeight="900.0" preserveRatio="false" />
        <ImageView fx:id="gameCloud5B" fitWidth="1400.0" fitHeight="900.0" preserveRatio="false" />

        <!-- Board View (1 noble row, 3 card rows)-->
        <StackPane fx:id="boardContainer"
           AnchorPane.topAnchor="60.0"
           AnchorPane.bottomAnchor="100.0"
           AnchorPane.leftAnchor="80.0"
           AnchorPane.rightAnchor="170.0" />

        <!-- Token Box on the right side-->
        <VBox fx:id="tokenBox"
              spacing="14.0"
              alignment="TOP_CENTER"
              AnchorPane.topAnchor="40.0"
              AnchorPane.rightAnchor="30.0">

            <padding>
                <Insets top="10.0" right="10.0" bottom="10.0" left="10.0"/>
            </padding>

            <children>
                <Button fx:id="goldBtn" onAction="#onGoldTokenClick"
                        style="-fx-background-color: transparent; -fx-padding: 0;">
                    <graphic>
                        <ImageView fx:id="goldTokenView" fitWidth="72.0" fitHeight="72.0" preserveRatio="true" />
                    </graphic>
                </Button>

                <Button fx:id="greenBtn" onAction="#onGreenTokenClick"
                        style="-fx-background-color: transparent; -fx-padding: 0;">
                    <graphic>
                        <ImageView fx:id="greenTokenView" fitWidth="72.0" fitHeight="72.0" preserveRatio="true" />
                    </graphic>
                </Button>

                <Button fx:id="whiteBtn" onAction="#onWhiteTokenClick"
                        style="-fx-background-color: transparent; -fx-padding: 0;">
                    <graphic>
                        <ImageView fx:id="whiteTokenView" fitWidth="72.0" fitHeight="72.0" preserveRatio="true" />
                    </graphic>
                </Button>

                <Button fx:id="blackBtn" onAction="#onBlackTokenClick"
                        style="-fx-background-color: transparent; -fx-padding: 0;">
                    <graphic>
                        <ImageView fx:id="blackTokenView" fitWidth="72.0" fitHeight="72.0" preserveRatio="true" />
                    </graphic>
                </Button>

                <Button fx:id="redBtn" onAction="#onRedTokenClick"
                        style="-fx-background-color: transparent; -fx-padding: 0;">
                    <graphic>
                        <ImageView fx:id="redTokenView" fitWidth="72.0" fitHeight="72.0" preserveRatio="true" />
                    </graphic>
                </Button>

                <Button fx:id="blueBtn" onAction="#onBlueTokenClick"
                        style="-fx-background-color: transparent; -fx-padding: 0;">
                    <graphic>
                        <ImageView fx:id="blueTokenView" fitWidth="72.0" fitHeight="72.0" preserveRatio="true" />
                    </graphic>
                </Button>
            </children>
        </VBox>

        <!-- Bottom status bar -->
        <HBox fx:id="statusBar"
              alignment="CENTER_LEFT"
              prefHeight="56.0"
              spacing="12.0"
              style="-fx-background-color: rgba(15, 23, 42, 0.88);
                     -fx-background-radius: 14 14 0 0;
                     -fx-padding: 0 18 0 18;
                     -fx-border-color: rgba(255,255,255,0.12);
                     -fx-border-width: 1 0 0 0;"
              AnchorPane.leftAnchor="18.0"
              AnchorPane.rightAnchor="18.0"
              AnchorPane.bottomAnchor="12.0">
        
            <children>
                <Label fx:id="statusIcon"
                       text="ℹ"
                       minWidth="28.0"
                       minHeight="28.0"
                       alignment="CENTER"
                       style="-fx-background-color: rgba(59,130,246,0.95);
                              -fx-background-radius: 999;
                              -fx-text-fill: white;
                              -fx-font-size: 15px;
                              -fx-font-weight: bold;" />
        
                <Label fx:id="statusLabel"
                       text="Welcome to Splendor!"
                       maxWidth="1.7976931348623157E308"
                       HBox.hgrow="ALWAYS"
                       style="-fx-text-fill: white;
                              -fx-font-size: 15px;
                              -fx-font-weight: bold;" />
            </children>
        </HBox>

    </children>
</AnchorPane>